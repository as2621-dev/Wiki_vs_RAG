# Copy to .env and fill in real values. Never commit .env.
# .env is gitignored; .env.example is the onboarding contract.

# ─── LLM providers ────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ─── Backend (pick one) ───────────────────────────────────
# Convex
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Payments ─────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── Background jobs ──────────────────────────────────────
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_ID=

# ─── Corpus (movie-script Kaggle fallback) ────────────────
# Local dir of <book_key>.txt scripts from the Kaggle 'Movie Transcripts 59K' dump.
MOVIE_SCRIPTS_KAGGLE_DUMP_PATH=

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
